

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}


datasource db {
  provider = "postgresql"
}


enum UserRole {
  user
  admin
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?
  lastName      String?
  password      String
  role          UserRole  @default(user)
  phone         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  customerCode  String?
  deliveryTerms String?
  paymentTerms  String?

  // Common address fields (optional). For structured addresses consider using Json
  addressLine1  String?
  addressLine2  String?
  city          String?
  zip           String?

  // Flexible JSON fields for billing/shipping address objects
  billingAddress  Json?
  shippingAddress Json?
  // Credit information
  creditLimit     Decimal  @db.Decimal(10, 2) @default(0.00)
  creditUsed      Decimal  @db.Decimal(10, 2) @default(0.00)
  creditRemaining Decimal  @db.Decimal(10, 2) @default(0.00)
}

model CustomerPricing {
  id            String   @id @default(cuid())
  metaobjectId  String   @unique // Shopify metaobject GID
  customerId    String   // Shopify customer GID
  price         Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([metaobjectId])
}




