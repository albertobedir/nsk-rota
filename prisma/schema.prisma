

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}


datasource db {
  provider = "postgresql"
}


enum UserRole {
  user
  admin
}

enum StackingType {
  COMPOUND
  ADDITIVE
  MAX
}

enum DiscountValueType {
  PERCENTAGE
  FIXED_AMOUNT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?
  lastName      String?
  password      String
  role          UserRole  @default(user)
  phone         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  customerCode  String?
  deliveryTerms String?
  paymentTerms  String?

  // Common address fields (optional). For structured addresses consider using Json
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?   // Eyalet (IL, NY, vb)
  zip           String?

  // Flexible JSON fields for billing/shipping address objects
  billingAddress  Json?
  shippingAddress Json?
  // Credit information
  creditLimit     Decimal  @db.Decimal(10, 2) @default(0.00)
  creditUsed      Decimal  @db.Decimal(10, 2) @default(0.00)
  creditRemaining Decimal  @db.Decimal(10, 2) @default(0.00)
  
  // Shopify customer fields
  shopifyCustomerId String?  // Shopify customer GID (gid://shopify/Customer/...)
  shopifyTags       Json?
  tier              String?

  // Company information
  companyName       String?   // Müşteri şirket adı
  shopifyCompanyId  String?   // Shopify company GID (gid://shopify/Company/...)
  
  // Company address (Shopify company location için kullanılır)
  companyAddress1   String?   // Şirket adresi
  companyCity       String?   // Şirket şehri
  companyState      String?   // Şirket eyalet (IL, NY, vb)
  companyZip        String?   // Şirket posta kodu
}

model CustomerPricing {
  id              String   @id @default(cuid())
  metaobjectId    String   @unique // Shopify metaobject GID
  customerId      String   // Shopify customer GID
  productShopifyId String?  // Shopify product GID (for lookup by product)
  price           Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerId])
  @@index([productShopifyId])
  @@index([metaobjectId])
}


model Customer {
  id              String   @id @default(cuid())
  shopifyId       String   @unique
  email           String
  firstName       String?
  lastName        String?
  phone           String?
  creditLimit     Decimal? @db.Decimal(10, 2)
  creditUsed      Decimal? @db.Decimal(10, 2)
  creditRemaining Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopifyId])
}

model PricingTier {
  id                 String   @id @default(cuid())
  metaobjectId       String   @unique
  tierName           String
  tierTag            String   @unique
  discountPercentage Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tierTag])
}

model DiscountCode {
  id             String            @id @default(cuid())
  code           String            @unique
  shopifyId      String?           @unique
  title          String?
  
  // Discount tipi
  discountType   String?           // "BASIC" | "BXGY" | "FREE_SHIPPING"
  
  // Değer
  valueType      DiscountValueType @default(PERCENTAGE)
  value          Float             // % veya sabit tutar
  
  // BxGy alanları
  buyQuantity          Int?
  buyPurchaseAmount    Float?        // DiscountPurchaseAmount için (minimum spend)
  buyProductIds        String[]
  buyCollectionIds     String[]
  buyAnyProduct        Boolean      @default(false)
  getQuantity          Int?
  getProductIds        String[]
  getCollectionIds     String[]
  getAnyProduct        Boolean      @default(false)
  
  // Stacking
  stackingType   StackingType      @default(COMPOUND)
  allowedTiers   String[]          // ["GOLD", "SILVER"] boşsa herkese açık
  combinesWithOrderDiscounts    Boolean @default(false)
  combinesWithProductDiscounts  Boolean @default(false)
  combinesWithShippingDiscounts Boolean @default(false)
  
  // Koşullar
  minimumCartAmount     Float?        // min sepet tutarı
  minimumQuantity       Int?          // min ürün miktarı
  usageLimit            Int?          // null = sınırsız
  usedCount             Int           @default(0)
  appliesOncePerCustomer Boolean      @default(false)
  
  // Müşteri seçimi
  allCustomers      Boolean       @default(true)
  specificCustomers String[]      // Shopify customer GID'leri
  customerSegments  Json[]        // { id: String, name: String }[]
  
  // Ürün/koleksiyon seçimi (BASIC için)
  appliesToAll       Boolean       @default(false)
  appliesToProducts  String[]      // Shopify product GID'leri
  appliesToCollections String[]    // Shopify collection GID'leri
  
  // Durum
  active         Boolean           @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([code])
  @@index([shopifyId])
  @@index([active])
  @@index([allCustomers])
}

model DiscountUsage {
  id            String    @id @default(cuid())
  discountId    String
  customerId    String
  usedAt        DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@unique([discountId, customerId])
  @@index([discountId])
  @@index([customerId])
}